{
    "name": "olleksi/bbcodes",
    "description": "Кастомні BB-коди, приховування кнопок редактора та галерея Таро",
    "type": "flarum-extension",
    "require": {
        "flarum/core": ">=1.0.0"
    },
    "autoload": {
        "psr-4": {
            "Olleksi\\Bbcodes\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "BBCodes Manager",
            "icon": {
                "name": "fas fa-code",
                "backgroundColor": "#4a6fa5",
                "color": "#fff"
            }
        }
    }
}
